# 이 파일을 .env로 복사한 뒤 값을 채운다.
# !! 이 파일(.env.example)은 git이 추적한다. 실제 키를 여기 넣지 말 것. !!
#    실제 키는 .env에만 넣는다 (.gitignore가 무시한다).
#
# 1) LAW_OC — 국가법령정보 공동활용 OPEN API 인증값
#    https://open.law.go.kr/LSO/openApi/cuAskList.do 에서 신청.
#    공공데이터포털과 달리 랜덤 키가 발급되는 게 아니라, 본인이 지정하는
#    식별자다. 보통 가입 이메일의 @ 앞부분을 쓴다. 비밀값이 아니다.
#    확인·변경: https://open.law.go.kr/LSO/usr/usrOcInfoMod.do
LAW_OC=

# 2) DATA_GO_KR_SERVICE_KEY — 공공데이터포털 인증키 (Decoding 키 사용)
#    https://www.data.go.kr 가입 후 아래 두 API에 활용신청(개발계정 자동승인):
#      - 15121001 한국산업안전보건공단_국내재해사례 게시판 정보 조회서비스
#      - 15123696 한국산업안전보건공단_안전보건법령 스마트검색
#    두 API 모두 이용허락범위 제한 없음. 이건 비밀값이므로 절대 커밋 금지.
DATA_GO_KR_SERVICE_KEY=

# 3) GEMINI_API_KEY — Google AI Studio 인증키 (5단계 RAG 생성기)
#    https://aistudio.google.com/apikey 에서 발급. 무료 티어가 있다.
#    비밀값이므로 절대 커밋 금지. 키가 없어도 1~4단계(판정)는 정상 동작하고,
#    생성기는 설명 없이 룰엔진 판정만 돌려준다.
GEMINI_API_KEY=
